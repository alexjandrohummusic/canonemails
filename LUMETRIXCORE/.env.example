# Copia a .env y ajusta
APP_SECRET=cambia-esto-por-una-cadena-larga-y-secreta
DATABASE_URL=sqlite:///./lumetrix.db
# Para producción: postgresql+psycopg://user:pass@postgres:5432/lumetrix
REDIS_URL=redis://localhost:6379/0
# Modo de envío: background (sin Redis, para demo) | celery (producción)
SEND_MODE=background
# Modelo de IA para el copy: haiku (recomendado) | sonnet | opus | fable
AI_MODEL=haiku
# Modo de IA: managed (la plataforma pone el token) | byo (cada usuario pone el suyo)
AI_MODE=managed
# API key de Anthropic de la PLATAFORMA (modo gestionado). El cliente NO la ve.
PLATFORM_AI_TOKEN=
# Pacing anti-spam (variables estáticas para probar valores)
WARMUP_MAX_PER_HOUR=200
WARMUP_MAX_PER_DAY=1000
SEND_MIN_DELAY_SEC=8
SEND_MAX_DELAY_SEC=25
SEND_PAUSE_EVERY=50
SEND_PAUSE_SECONDS=300
BOUNCE_RATE_LIMIT=0.02
COMPLAINT_RATE_LIMIT=0.003
# Retención de campañas (días)
RETENTION_DAYS=15
